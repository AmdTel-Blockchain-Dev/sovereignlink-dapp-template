---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={Astro.props.description ??
        "SovereignLink – decentralised identity dApp"}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>
      // Open Props theming is fully local: read preference from localStorage only.
      // Sovereign/privacy principle: no backend call and no tracking for theme state.
      (() => {
        const THEME_KEY = "sovereignlink-theme";
        const root = document.documentElement;

        try {
          const savedTheme = localStorage.getItem(THEME_KEY);
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const initialTheme =
            savedTheme === "light" || savedTheme === "dark"
              ? savedTheme
              : prefersDark
                ? "dark"
                : "light";

          root.setAttribute("data-theme", initialTheme);
        } catch {
          root.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <title>{Astro.props.title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
