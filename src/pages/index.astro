---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SovereignLink">
  <main
    style="padding: var(--size-8); max-inline-size: var(--size-content-3); margin-inline: auto; display: grid; gap: var(--size-5);"
  >
    <h1 style="font-size: var(--font-size-6); font-weight: var(--font-weight-7); margin-block-end: var(--size-4);">
      SovereignLink
    </h1>
    <p style="font-size: var(--font-size-3); color: var(--gray-7);">
      Decentralised identity dApp — Astro + Lit + Midnight + Cardano
    </p>
    <section style="display: grid; gap: var(--size-4);">
      <wallet-connect></wallet-connect>
      <sovereign-profile></sovereign-profile>
    </section>
  </main>
  <script>
    import "../components/SovereignProfile.ts";
import "../components/WalletConnect.ts";
  </script>
</Layout>
