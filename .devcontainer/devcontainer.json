{
  "name": "SovereignLink – Astro + Lit + Midnight + Cardano (Open Props)",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // Core Astro + Lit + TypeScript support
        "astro-build.astro-vscode",
        "biomejs.biome",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",

        // Midnight Compact language support (official)
        "midnight-ntwrk.compact-vscode",

        // General helpers (minimal)
        "eamodio.gitlens",
        "github.copilot",
        "github.copilot-chat",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[astro]": {
          "editor.defaultFormatter": "astro-build.astro-vscode"
        },
        "[css]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[json]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescript]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "biomejs.biome"
        },
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "explicit"
        },
        "js/ts.tsdk.path": "node_modules/typescript/lib",
        "astro.typescript.enable": true,
        "files.associations": {
          "*.compact": "compact"
        },
        // Open Props friendly settings
        "css.customData": [".vscode/open-props.json"],
        "editor.quickSuggestions": {
          "strings": true
        }
      }
    }
  },
  "onCreateCommand": "npm install -g pnpm",
  "postCreateCommand": "bash -c 'echo \"Installing Midnight Compact toolchain...\" && curl --proto \"=https\" --tlsv1.2 -LsSf https://github.com/midnightntwrk/compact/releases/latest/download/compact-installer.sh | sh && echo \"export PATH=\\$HOME/.cargo/bin:\\$PATH\" >> ~/.bashrc && source ~/.bashrc && compact update && pnpm install && echo \"✅ SovereignLink dev environment ready with Open Props! Run: pnpm run dev\"'",
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": {
      "label": "Astro Dev Server",
      "onAutoForward": "openPreview"
    }
  },
  "remoteUser": "node",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "32gb"
  }
}
